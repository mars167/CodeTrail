{
  "name": "@mars167/codetrail",
  "version": "0.1.7-beta.6",
  "description": "CodeTrail: deterministic-first code search with reliability-labeled evidence",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mars167/CodeTrail"
  },
  "bin": {
    "codetrail": "bin/codetrail.js",
    "codetrail-skills": "bin/codetrail.js"
  },
  "files": [
    "bin/",
    "lib/",
    "assets/",
    "package.json"
  ],
  "scripts": {
    "test": "node --test test/*.test.js",
    "check:versions": "node ../scripts/npm/check-versions.js",
    "check:assets": "node ../scripts/npm/check-agent-assets.js",
    "sync:assets": "node ../scripts/npm/check-agent-assets.js --write",
    "smoke": "node ../scripts/npm/smoke.js"
  },
  "optionalDependencies": {
    "@mars167/core-darwin-arm64": "0.1.7-beta.6",
    "@mars167/core-darwin-x64": "0.1.7-beta.6",
    "@mars167/core-linux-arm64": "0.1.7-beta.6",
    "@mars167/core-linux-x64": "0.1.7-beta.6",
    "@mars167/core-win32-arm64": "0.1.7-beta.6",
    "@mars167/core-win32-x64": "0.1.7-beta.6"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
